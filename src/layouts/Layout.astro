---
import Header from '../components/Header.astro';
import Line from '../components/Line.astro'

const {
  logos,
  primaryColor,
  showNav = true,
} = Astro.props;

const outerContainerWidth = '1536px';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='12' fill='%230a0a0a'/%3E%3Ctext x='50%25' y='52%25' dominant-baseline='middle' text-anchor='middle' font-family='monospace' font-size='22' font-weight='bold' fill='%23ffffff'%3EDL%3C/text%3E%3C/svg%3E" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Geist+Mono&family=Open+Sans&family=Poppins&family=Roboto&family=Roboto+Mono&display=swap" rel="stylesheet">
    <script is:inline src="/scripts/main.js"></script>
    <!-- Prevent flash of wrong theme: apply stored theme before first paint -->
    <script is:inline>
      (function () {
        var stored = localStorage.getItem("theme");
        var theme = stored || "dark";
        if (theme === "dark") {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
  </head>
  <body
    style={`--outer-container-width: ${outerContainerWidth}; --font-sans: 'Open Sans', sans-serif; ${primaryColor ? `--color-primary: ${primaryColor};` : ''}`}
    class="font-sans bg-background text-foreground selection:bg-primary"
  >
    <svg width="0" height="0" display="none" xmlns="http://www.w3.org/2000/svg">
      <symbol id="star" viewBox="0 0 24 24" fill="currentColor" class="stroke-amber-400" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2">
        </polygon>
      </symbol>
    </svg>  
    <div class="grid min-h-screen grid-rows-[auto_1fr] grid-cols-[minmax(1em,1fr)_minmax(0,var(--outer-container-width))_minmax(1em,1fr)]">
      <Header logos={logos} showNav={showNav} />
      <main class="col-start-2 bg-background border-x border-border">
        <slot />
        <Line />
      </main>
    </div>
  </body>
</html>
