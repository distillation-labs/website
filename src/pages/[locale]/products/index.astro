---
import Line from '@/components/Line.astro';
import Layout from '@/layouts/Layout.astro';
import getAvailableLocales from '@/lib/i18n.js';
import getProductsContent from '@/lib/productsContent';
import getTranslations from '@/lib/translations';
import { getRelativeLocaleUrl } from 'astro:i18n';

import '../../../styles/style.css';

export function getStaticPaths() {
  const availableLocales = getAvailableLocales();
  return availableLocales.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale ?? 'en';
const t = getTranslations(locale);
const content = getProductsContent(locale);
---

<Layout title={content.breadcrumb} description={content.heroDescription}>
  <section class="border-b border-border px-6 md:px-8 pt-12 md:pt-16 pb-12 md:pb-16">
    <div class="grid gap-10 xl:grid-cols-[minmax(0,1.2fr)_minmax(300px,0.8fr)] xl:items-end">
      <div class="flex flex-col gap-6">
        <div class="flex flex-wrap items-center gap-3 text-[10px] font-mono uppercase tracking-[0.24em] text-muted">
          <span>Distillation Labs</span>
          <span class="opacity-40">/</span>
          <span>{content.breadcrumb}</span>
        </div>
        <div class="flex flex-col gap-4">
          <h1 class="font-mono text-[clamp(3rem,9vw,6rem)] font-bold uppercase leading-[0.9] tracking-tight">
            {content.heroTitle}
          </h1>
          <p class="max-w-3xl text-base leading-relaxed text-muted">
            {content.heroDescription}
          </p>
        </div>
      </div>

      <div class="border border-border bg-card/50 px-5 py-5">
        <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-muted">{content.thesisLabel}</p>
        <h2 class="mt-3 font-mono text-2xl font-bold uppercase leading-none">{content.thesisTitle}</h2>
        <p class="mt-4 text-sm leading-relaxed text-muted">{content.thesisParagraphs[0]}</p>
      </div>
    </div>
  </section>

  <section class="px-6 md:px-8 py-12 md:py-16">
    <div class="grid gap-10 lg:grid-cols-[220px_minmax(0,1fr)]">
      <div>
        <p class="font-mono text-[10px] uppercase tracking-[0.24em] text-muted">{t.productsLabel}</p>
      </div>
      <div class="grid gap-px border border-border bg-border md:grid-cols-2">
        <article class="bg-background px-5 py-6">
          <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-muted">{t.repositoryIntelligenceLabel}</p>
          <h2 class="mt-3 font-mono text-2xl font-bold uppercase leading-none">{t.contextroName}</h2>
          <p class="mt-4 text-sm leading-relaxed text-muted">{t.contextroDesc}</p>
          <div class="mt-5 flex flex-wrap items-center gap-4">
            <a href={getRelativeLocaleUrl(locale, '/contextro')} class="corner-effect select-none">
              <span class="corner"></span>
              <span class="relative z-10 block rounded-sm bg-primary px-4 py-2 text-xs font-mono uppercase tracking-[0.2em] text-primary-foreground">
                {t.productPageLabel}
              </span>
            </a>
            <a href={getRelativeLocaleUrl(locale, '/contextro/docs')} class="font-mono text-[10px] uppercase tracking-[0.2em] text-muted underline underline-offset-4 transition-colors hover:text-foreground">
              {t.docsLabel}
            </a>
          </div>
        </article>

        <article class="bg-background px-5 py-6">
          <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-muted">{t.browserAutomationLabel}</p>
          <h2 class="mt-3 font-mono text-2xl font-bold uppercase leading-none">{t.agentycName}</h2>
          <p class="mt-4 text-sm leading-relaxed text-muted">{t.agentycDesc}</p>
          <div class="mt-5 flex flex-wrap items-center gap-4">
            <a href={getRelativeLocaleUrl(locale, '/agentyc')} class="corner-effect select-none">
              <span class="corner"></span>
              <span class="relative z-10 block rounded-sm bg-primary px-4 py-2 text-xs font-mono uppercase tracking-[0.2em] text-primary-foreground">
                {t.productPageLabel}
              </span>
            </a>
            <a href={getRelativeLocaleUrl(locale, '/agentyc/docs')} class="font-mono text-[10px] uppercase tracking-[0.2em] text-muted underline underline-offset-4 transition-colors hover:text-foreground">
              {t.docsLabel}
            </a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <Line />

  <section class="px-6 md:px-8 py-12 md:py-16">
    <div class="grid gap-10 lg:grid-cols-[220px_minmax(0,1fr)]">
      <div>
        <p class="font-mono text-[10px] uppercase tracking-[0.24em] text-muted">{content.thesisLabel}</p>
      </div>
      <div class="flex max-w-4xl flex-col gap-4">
        <h2 class="font-mono text-3xl font-bold uppercase leading-none">{content.thesisTitle}</h2>
        {content.thesisParagraphs.map((paragraph) => (
          <p class="text-sm leading-relaxed text-muted md:text-base">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <Line />

  <section class="px-6 md:px-8 py-12 md:py-16">
    <div class="grid gap-10 lg:grid-cols-[220px_minmax(0,1fr)]">
      <div>
        <p class="font-mono text-[10px] uppercase tracking-[0.24em] text-muted">{content.fitLabel}</p>
      </div>
      <div class="grid gap-px border border-border bg-border md:grid-cols-3">
        {content.fitCards.map((card) => (
          <article class="bg-background px-5 py-6">
            <h2 class="font-mono text-lg font-bold uppercase">{card.title}</h2>
            <p class="mt-3 text-sm leading-relaxed text-muted">{card.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <Line />

  <section class="px-6 md:px-8 py-12 md:py-16">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="font-mono text-[10px] uppercase tracking-[0.24em] text-muted">{content.nextStepLabel}</p>
        <h2 class="mt-3 font-mono text-3xl font-bold uppercase leading-none">{content.nextStepTitle}</h2>
        <p class="mt-4 max-w-3xl text-sm leading-relaxed text-muted md:text-base">
          {content.nextStepBody}
        </p>
      </div>
      <div class="flex flex-wrap items-center gap-4">
        <a href={getRelativeLocaleUrl(locale, '/contextro')} class="corner-effect select-none">
          <span class="corner"></span>
          <span class="relative z-10 block rounded-sm bg-primary px-4 py-2 text-xs font-mono uppercase tracking-[0.2em] text-primary-foreground">
            {t.exploreContextro}
          </span>
        </a>
        <a href={getRelativeLocaleUrl(locale, '/agentyc')} class="corner-effect select-none">
          <span class="corner"></span>
          <span class="relative z-10 block rounded-sm bg-card px-4 py-2 text-xs font-mono uppercase tracking-[0.2em]">
            {t.exploreAgentyc}
          </span>
        </a>
      </div>
    </div>
  </section>
</Layout>
