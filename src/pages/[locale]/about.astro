---
import Layout from '@/layouts/Layout.astro';
import Line from '@/components/Line.astro';
import getAvailableLocales from '@/lib/i18n.js';
import getTranslations from '@/lib/translations';
import getPageContent from '@/lib/pageContent';

import '../../styles/style.css';

export function getStaticPaths() {
  const availableLocales = getAvailableLocales();
  return availableLocales.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale ?? 'en';
const t = getTranslations(locale);
const content = getPageContent(locale).about;
---

<Layout title={content.breadcrumb} description={content.heroDescription}>
  <section class="border-b border-border px-6 md:px-8 pt-12 md:pt-16 pb-12 md:pb-16">
    <div class="grid gap-10 xl:grid-cols-[minmax(0,1.15fr)_minmax(300px,0.85fr)] xl:items-end">
      <div class="flex flex-col gap-6">
        <div class="flex flex-wrap items-center gap-3 text-[10px] font-mono uppercase tracking-[0.24em] text-muted">
          <span>Distillation Labs</span>
          <span class="opacity-40">/</span>
          <span>{content.breadcrumb}</span>
        </div>
        <div class="flex flex-col gap-4">
          <h1 class="font-mono text-[clamp(2.75rem,8vw,5.75rem)] font-bold uppercase leading-[0.9] tracking-tight">
            {content.heroTitle}
          </h1>
          <p class="max-w-3xl text-base leading-relaxed text-muted">
            {content.heroDescription}
          </p>
        </div>
      </div>

      <div class="grid gap-px border border-border bg-border">
        {content.principles.map((item) => (
          <article class="bg-background px-5 py-5">
            <h2 class="font-mono text-lg font-bold uppercase">{item.title}</h2>
            <p class="mt-3 text-sm leading-relaxed text-muted">{item.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  {content.sections.map((section, index) => (
    <Fragment>
      <section class="px-6 md:px-8 py-12 md:py-16">
        <div class="grid gap-10 lg:grid-cols-[220px_minmax(0,1fr)]">
          <div>
            <p class="font-mono text-[10px] uppercase tracking-[0.24em] text-muted">{section.eyebrow}</p>
          </div>
          <div class="flex flex-col gap-5">
            <h2 class="font-mono text-3xl font-bold uppercase leading-none">{section.title}</h2>
            <div class="grid gap-4 max-w-3xl">
              {section.paragraphs.map((paragraph) => (
                <p class="text-sm leading-relaxed text-muted md:text-base">{paragraph}</p>
              ))}
            </div>
          </div>
        </div>
      </section>
      {index < content.sections.length - 1 && <Line />}
    </Fragment>
  ))}

  <Line />

      <section class="px-6 md:px-8 py-12 md:py-16">
    <div class="grid gap-10 lg:grid-cols-[220px_minmax(0,1fr)]">
      <div>
        <p class="font-mono text-[10px] uppercase tracking-[0.24em] text-muted">{content.howWeWorkLabel}</p>
      </div>
      <div class="grid gap-px border border-border bg-border md:grid-cols-2">
        {content.commitments.map((item) => (
          <article class="bg-background px-5 py-6">
            <h2 class="font-mono text-lg font-bold uppercase">{item.title}</h2>
            <p class="mt-3 text-sm leading-relaxed text-muted">{item.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <Line />

  <section class="px-6 md:px-8 py-12 md:py-16">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="font-mono text-[10px] uppercase tracking-[0.24em] text-muted">{content.currentProductsLabel}</p>
        <h2 class="mt-3 font-mono text-3xl font-bold uppercase leading-none">{content.currentProductsTitle}</h2>
        <p class="mt-4 max-w-3xl text-sm leading-relaxed text-muted md:text-base">
          {content.currentProductsBody}
        </p>
      </div>
      <div class="flex flex-wrap items-center gap-4">
        <a href={`/${Astro.currentLocale ?? 'en'}/contextro`} class="corner-effect select-none">
          <span class="corner"></span>
          <span class="relative z-10 block rounded-sm bg-primary px-4 py-2 text-xs font-mono uppercase tracking-[0.2em] text-primary-foreground">
              {t.exploreContextro}
            </span>
          </a>
        <a href={`/${Astro.currentLocale ?? 'en'}/agentyc`} class="corner-effect select-none">
          <span class="corner"></span>
          <span class="relative z-10 block rounded-sm bg-card px-4 py-2 text-xs font-mono uppercase tracking-[0.2em]">
            {t.exploreAgentyc}
          </span>
        </a>
      </div>
    </div>
  </section>
</Layout>
