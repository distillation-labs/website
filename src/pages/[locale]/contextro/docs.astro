---
import Layout from '@/layouts/Layout.astro';
import getAvailableLocales from '@/lib/i18n.js';
import getTranslations from '@/lib/translations';
import getPageContent from '@/lib/pageContent';
import { getRelativeLocaleUrl } from 'astro:i18n';

import '../../../styles/style.css';

export function getStaticPaths() {
  const availableLocales = getAvailableLocales();
  return availableLocales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
const t = getTranslations(locale);
const content = getPageContent(locale).contextroDocs;

const commands = [
  {
    group: 'Start here',
    items: [
      { cmd: 'status()', desc: 'Check whether a repository is indexed, which branch is active, and whether the server is ready.' },
      { cmd: 'index(path="/path/to/project")', desc: 'Index a codebase once, then refresh incrementally after changes.' },
      { cmd: 'overview()', desc: 'Summarize repository structure, languages, and dominant directories.' },
      { cmd: 'architecture()', desc: 'Map layers, hubs, boundaries, and entry points.' },
    ],
  },
  {
    group: 'Search & change safety',
    items: [
      { cmd: 'search(query="authentication flow")', desc: 'Hybrid semantic, keyword, and graph retrieval for behavior-oriented questions.' },
      { cmd: 'find_symbol(name="IndexingPipeline")', desc: 'Locate a symbol even when the name is approximate.' },
      { cmd: 'impact(symbol_name="TokenBudget")', desc: 'Estimate what breaks before you rename, delete, or move shared code.' },
      { cmd: 'code(operation="pattern_search", ...)', desc: 'Run AST-based symbol search, structural search, and rewrites.' },
      { cmd: 'commit_search(query="payment flow refactor")', desc: 'Search git history by meaning, not only by exact text.' },
    ],
  },
  {
    group: 'Memory & knowledge',
    items: [
      { cmd: 'remember(content="...")', desc: 'Store decisions, conventions, and debugging notes for later reuse.' },
      { cmd: 'knowledge(command="add", ...)', desc: 'Index docs, notes, or directories alongside the codebase.' },
      { cmd: 'restore()', desc: 'Rebuild project context when you return to the repo later.' },
      { cmd: 'compact(content="...")', desc: 'Archive large session context and retrieve it on demand.' },
    ],
  },
];

const configRows = [
  { key: 'CTX_STORAGE_DIR', value: '~/.contextro', detail: 'Base directory for indexes, caches, memory, and session state.' },
  { key: 'CTX_EMBEDDING_MODEL', value: 'potion-code-16m', detail: 'Local embedding model used for semantic retrieval.' },
  { key: 'CTX_TRANSPORT', value: 'stdio', detail: 'Use `stdio` for local MCP clients or `http` for service and container deployments.' },
  { key: 'CTX_HTTP_HOST', value: '0.0.0.0', detail: 'Bind address when running in HTTP mode.' },
  { key: 'CTX_HTTP_PORT', value: '8000', detail: 'Port exposed by the HTTP transport.' },
  { key: 'CTX_PATH_PREFIX_MAP', value: '/host/repo:/repos/platform', detail: 'Optional host-to-container path remap for mounted repositories.' },
];

const perfStats = [
  { metric: 'Cold start', value: '<50ms' },
  { metric: 'Warm search latency', value: '<1ms' },
  { metric: 'Indexing guidance', value: '~2s for 3,000 files' },
  { metric: 'Idle memory', value: '<50MB' },
  { metric: 'Binary size', value: '~9MB stripped' },
  { metric: 'Tool surface', value: '35 MCP tools' },
];

const troubleshooting = [
  {
    issue: 'Agent cannot launch Contextro',
    fix: 'Verify `command -v contextro` returns a binary and that your MCP client points to `contextro`. For zero-install setups, use `npx -y contextro@latest`.',
  },
  {
    issue: 'Results feel stale after a refactor',
    fix: 'Run `index(path="/path/to/project")` again. Contextro refreshes incrementally, but large branch switches or moved directories still need a re-index.',
  },
  {
    issue: 'Docker paths do not match host paths',
    fix: 'Set `CTX_CODEBASE_HOST_PATH`, `CTX_CODEBASE_MOUNT_PATH`, and `CTX_PATH_PREFIX_MAP` so the server can map client paths to the mounted repository.',
  },
  {
    issue: 'Global install finished but `contextro` is not found',
    fix: 'Check your npm global bin directory is on `PATH`, or use `npx contextro@latest` to run without a global install.',
  },
];
---

<Layout title={content.title} description={content.intro}>
  <section class="border-b border-border px-6 lg:px-8 pt-10 pb-8">
    <div class="flex flex-col gap-6 xl:flex-row xl:items-end xl:justify-between">
      <div class="flex flex-col gap-4">
        <p class="font-mono text-[10px] uppercase tracking-[0.24em] text-muted">
          Distillation Labs / {t.contextroName} / {content.breadcrumb}
        </p>
        <div class="flex flex-col gap-3">
          <h1 class="font-mono text-4xl font-bold uppercase leading-none md:text-5xl">{content.title}</h1>
          <p class="text-sm leading-relaxed text-muted lg:text-base">
            {content.intro}
          </p>
        </div>
      </div>
      <div class="flex flex-wrap items-center gap-4">
        <a href={getRelativeLocaleUrl(locale, '/contextro')} class="corner-effect select-none">
          <span class="corner"></span>
            <span class="relative z-10 block rounded-sm bg-card px-4 py-2 text-xs font-mono uppercase tracking-[0.2em]">
              {t.productPageLabel}
            </span>
          </a>
          <a href="https://github.com/distillation-labs/contextro" target="_blank" rel="noopener noreferrer" class="corner-effect select-none">
            <span class="corner"></span>
            <span class="relative z-10 block rounded-sm bg-primary px-4 py-2 text-xs font-mono uppercase tracking-[0.2em] text-primary-foreground">
              GitHub ↗
            </span>
          </a>
        </div>
      </div>
  </section>

  <div class="grid min-h-[72vh] grid-cols-1 xl:grid-cols-[280px_minmax(0,1fr)]">
    <aside class="border-b border-border px-6 py-8 xl:border-b-0 xl:border-r xl:px-5">
      <div class="xl:sticky xl:top-6 xl:flex xl:flex-col xl:gap-8">
        <div>
          <p class="font-mono text-[10px] uppercase tracking-[0.24em] text-muted">{content.onPageLabel}</p>
          <ul class="mt-4 flex flex-wrap gap-2 xl:flex-col xl:gap-1">
            {content.sections.map((section) => (
              <li>
                <a href={`#${section.id}`} class="block py-1 font-mono text-[11px] uppercase tracking-[0.16em] text-muted transition-colors hover:text-foreground">
                  {section.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="border border-border bg-card/60 p-4">
          <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-muted">{content.quickInstallLabel}</p>
          <code class="mt-3 block font-mono text-sm text-foreground">npm install -g contextro</code>
          <p class="mt-3 text-xs leading-relaxed text-muted">
            {content.quickInstallBody}
          </p>
        </div>
      </div>
    </aside>

    <div class="min-w-0 px-6 py-8 lg:px-8">
      <div class="flex flex-col gap-12">
        <section id="overview" class="scroll-mt-8">
          <div class="grid gap-6 2xl:grid-cols-[minmax(0,1.2fr)_minmax(280px,0.8fr)]">
            <div class="flex flex-col gap-4">
              <h2 class="font-mono text-2xl font-bold uppercase">{content.overviewHeading}</h2>
              {content.overviewParagraphs.map((paragraph) => (
                <p class="text-sm leading-relaxed text-muted lg:text-base">{paragraph}</p>
              ))}
            </div>
            <div class="grid gap-px border border-border bg-border sm:grid-cols-2 2xl:grid-cols-1">
              <div class="bg-background px-5 py-5">
                <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-muted">{content.withoutLabel}</p>
                <p class="mt-3 text-sm leading-relaxed text-muted">
                  {content.withoutBody}
                </p>
              </div>
              <div class="bg-background px-5 py-5">
                <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-muted">{content.withLabel}</p>
                <p class="mt-3 text-sm leading-relaxed text-muted">
                  {content.withBody}
                </p>
              </div>
            </div>
          </div>
        </section>

        <section id="installation" class="scroll-mt-8 border-t border-border pt-12">
          <div class="grid gap-8 xl:grid-cols-[minmax(0,1fr)_minmax(320px,0.9fr)]">
            <div class="flex flex-col gap-4">
              <h2 class="font-mono text-2xl font-bold uppercase">{content.installationHeading}</h2>
              <p class="text-sm leading-relaxed text-muted lg:text-base">
                {content.installationIntro}
              </p>
              <div class="grid gap-3">
                <pre class="overflow-x-auto border border-border bg-card px-4 py-4 text-sm font-mono"><code>npm install -g contextro</code></pre>
                <pre class="overflow-x-auto border border-border bg-card px-4 py-4 text-sm font-mono"><code>npx contextro@latest</code></pre>
                <pre class="overflow-x-auto border border-border bg-card px-4 py-4 text-sm font-mono"><code>cargo install --path contextro-server</code></pre>
              </div>
              <p class="text-xs leading-relaxed text-muted">
                {content.installationFootnote}
              </p>
            </div>
            <div class="border border-border bg-card/50 px-5 py-5">
              <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-muted">{content.compatibilityLabel}</p>
              <ul class="mt-4 flex flex-col gap-3 text-sm text-muted">
                {content.compatibilityItems.map((item) => <li>{item}</li>)}
              </ul>
            </div>
          </div>
        </section>

        <section id="quickstart" class="scroll-mt-8 border-t border-border pt-12">
          <h2 class="font-mono text-2xl font-bold uppercase">{content.quickstartHeading}</h2>
          <div class="mt-6 grid gap-px border border-border bg-border lg:grid-cols-4">
            <article class="bg-background px-5 py-5">
              <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-muted">01</p>
              <h3 class="mt-3 font-mono text-base font-bold uppercase">{content.quickstartSteps[0]}</h3>
              <pre class="mt-4 overflow-x-auto border border-border bg-card px-4 py-3 text-xs font-mono"><code>npm install -g contextro</code></pre>
            </article>
            <article class="bg-background px-5 py-5">
              <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-muted">02</p>
              <h3 class="mt-3 font-mono text-base font-bold uppercase">{content.quickstartSteps[1]}</h3>
              <pre class="mt-4 overflow-x-auto border border-border bg-card px-4 py-3 text-xs font-mono"><code>claude mcp add contextro -- contextro</code></pre>
            </article>
            <article class="bg-background px-5 py-5">
              <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-muted">03</p>
              <h3 class="mt-3 font-mono text-base font-bold uppercase">{content.quickstartSteps[2]}</h3>
              <pre class="mt-4 overflow-x-auto border border-border bg-card px-4 py-3 text-xs font-mono"><code>index(path="/path/to/project")</code></pre>
            </article>
            <article class="bg-background px-5 py-5">
              <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-muted">04</p>
              <h3 class="mt-3 font-mono text-base font-bold uppercase">{content.quickstartSteps[3]}</h3>
              <pre class="mt-4 overflow-x-auto border border-border bg-card px-4 py-3 text-xs font-mono"><code>search(query="how does authentication work")</code></pre>
            </article>
          </div>
        </section>

        <section id="clients" class="scroll-mt-8 border-t border-border pt-12">
          <h2 class="font-mono text-2xl font-bold uppercase">{content.clientsHeading}</h2>
          <div class="mt-6 grid gap-6 xl:grid-cols-3">
            <article class="border border-border bg-background px-5 py-5">
              <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-muted">Claude Code</p>
              <pre class="mt-4 overflow-x-auto border border-border bg-card px-4 py-4 text-sm font-mono"><code>claude mcp add contextro -- contextro</code></pre>
            </article>
            <article class="border border-border bg-background px-5 py-5">
              <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-muted">Claude Desktop / Cursor / Windsurf</p>
              <pre class="mt-4 overflow-x-auto border border-border bg-card px-4 py-4 text-sm font-mono"><code>{`{
  "mcpServers": {
    "contextro": {
      "command": "contextro"
    }
  }
}`}</code></pre>
              <p class="mt-3 text-xs leading-relaxed text-muted">
                {content.clientsDesktopHelp}
              </p>
            </article>
            <article class="border border-border bg-background px-5 py-5">
              <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-muted">HTTP mode</p>
              <pre class="mt-4 overflow-x-auto border border-border bg-card px-4 py-4 text-sm font-mono"><code>CTX_TRANSPORT=http CTX_HTTP_HOST=0.0.0.0 CTX_HTTP_PORT=8000 contextro</code></pre>
              <p class="mt-3 text-xs leading-relaxed text-muted">
                {content.httpModeBody}
              </p>
            </article>
          </div>
        </section>

        <section id="configuration" class="scroll-mt-8 border-t border-border pt-12">
          <h2 class="font-mono text-2xl font-bold uppercase">{content.configurationHeading}</h2>
          <p class="mt-4 text-sm leading-relaxed text-muted lg:text-base">
            {content.configurationIntro}
          </p>
          <div class="mt-6 overflow-x-auto border border-border">
            <table class="min-w-full border-collapse text-left">
              <thead class="bg-card">
                <tr>
                  <th class="border-b border-border px-4 py-3 font-mono text-[10px] uppercase tracking-[0.2em] text-muted">{content.tableHeaders[0]}</th>
                  <th class="border-b border-border px-4 py-3 font-mono text-[10px] uppercase tracking-[0.2em] text-muted">{content.tableHeaders[1]}</th>
                  <th class="border-b border-border px-4 py-3 font-mono text-[10px] uppercase tracking-[0.2em] text-muted">{content.tableHeaders[2]}</th>
                </tr>
              </thead>
              <tbody>
                {configRows.map((row) => (
                  <tr class="align-top odd:bg-background even:bg-card/40">
                    <td class="border-b border-border px-4 py-4 font-mono text-sm text-foreground">{row.key}</td>
                    <td class="border-b border-border px-4 py-4 font-mono text-xs text-muted">{row.value}</td>
                    <td class="border-b border-border px-4 py-4 text-sm leading-relaxed text-muted">{row.detail}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>

        <section id="commands" class="scroll-mt-8 border-t border-border pt-12">
          <h2 class="font-mono text-2xl font-bold uppercase">{content.commandsHeading}</h2>
          <p class="mt-4 text-sm leading-relaxed text-muted lg:text-base">
            {content.commandsIntro}
          </p>
          <div class="mt-6 flex flex-col gap-8">
            {commands.map((group) => (
              <div class="flex flex-col gap-3">
                <p class="font-mono text-[10px] uppercase tracking-[0.24em] text-muted">{group.group}</p>
                <div class="grid gap-px border border-border bg-border">
                  {group.items.map((item) => (
                    <div class="grid gap-3 bg-background px-4 py-4 lg:grid-cols-[minmax(0,360px)_minmax(0,1fr)] lg:items-start lg:gap-6">
                      <div class="min-w-0">
                        <code class="block min-w-0 break-words font-mono text-sm leading-relaxed text-foreground">{item.cmd}</code>
                      </div>
                      <p class="min-w-0 text-sm leading-relaxed text-muted">{item.desc}</p>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </section>

        <section id="indexing" class="scroll-mt-8 border-t border-border pt-12">
          <h2 class="font-mono text-2xl font-bold uppercase">{content.indexingHeading}</h2>
          <div class="mt-6 grid gap-px border border-border bg-border xl:grid-cols-4">
            <div class="bg-background px-5 py-5">
              <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-muted">Chunking</p>
              <p class="mt-3 text-sm leading-relaxed text-muted">Splits code into symbol-aware slices so functions, classes, and related context stay retrievable as coherent units.</p>
            </div>
            <div class="bg-background px-5 py-5">
              <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-muted">Embeddings</p>
              <p class="mt-3 text-sm leading-relaxed text-muted">Builds vector representations for semantic search using a code-oriented embedding model optimized for local speed.</p>
            </div>
            <div class="bg-background px-5 py-5">
              <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-muted">Graph</p>
              <p class="mt-3 text-sm leading-relaxed text-muted">Stores symbol relationships, call edges, and architectural connections to make dependency-aware retrieval possible.</p>
            </div>
            <div class="bg-background px-5 py-5">
              <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-muted">Warm start and incremental updates</p>
              <p class="mt-3 text-sm leading-relaxed text-muted">Persists indexes to disk, restores them on restart, and reprocesses only changed files instead of rebuilding everything from scratch.</p>
            </div>
          </div>
        </section>

        <section id="retrieval" class="scroll-mt-8 border-t border-border pt-12">
          <h2 class="font-mono text-2xl font-bold uppercase">{content.retrievalHeading}</h2>
          <ol class="mt-6 grid gap-px border border-border bg-border xl:grid-cols-2">
            {[
              'Reuse cached results when the query or repo state already matches.',
              'Run vector, BM25, and graph retrieval in parallel against the indexed codebase.',
              'Apply exact-match boosts and fallback handling for strong lexical hits.',
              'Fuse candidates with reciprocal rank fusion.',
              'Optionally rerank the shortlist for higher precision.',
              'Apply diversity penalties so one file does not dominate the answer.',
              'Compress snippets with AST-aware rules before returning them to the model.',
              'Sandbox large responses instead of flooding the client with raw output.',
              'Attach compact metadata and confidence signals to the final result set.',
            ].map((step, index) => (
              <li class="bg-background px-5 py-5">
                <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-muted">Step {String(index + 1).padStart(2, '0')}</p>
                <p class="mt-3 text-sm leading-relaxed text-muted">{step}</p>
              </li>
            ))}
          </ol>
        </section>

        <section id="memory" class="scroll-mt-8 border-t border-border pt-12">
          <div class="grid gap-8 2xl:grid-cols-[minmax(0,1fr)_minmax(320px,0.8fr)]">
            <div>
              <h2 class="font-mono text-2xl font-bold uppercase">{content.memoryHeading}</h2>
              {content.memoryParagraphs.map((paragraph) => (
                <p class="mt-4 text-sm leading-relaxed text-muted lg:text-base">{paragraph}</p>
              ))}
            </div>
            <div class="border border-border bg-card/50 px-5 py-5">
              <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-muted">{content.memoryCandidatesLabel}</p>
              <ul class="mt-4 flex flex-col gap-3 text-sm leading-relaxed text-muted">
                <li>Build commands and environment assumptions</li>
                <li>Routing conventions and naming rules</li>
                <li>Verified architectural boundaries</li>
                <li>Known failure modes and their fixes</li>
              </ul>
            </div>
          </div>
        </section>

        <section id="performance" class="scroll-mt-8 border-t border-border pt-12">
          <h2 class="font-mono text-2xl font-bold uppercase">{content.performanceHeading}</h2>
          <div class="mt-6 grid gap-px border border-border bg-border md:grid-cols-2 xl:grid-cols-3">
            {perfStats.map((row) => (
              <div class="bg-background px-5 py-5">
                <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-muted">{row.metric}</p>
                <p class="mt-3 font-mono text-lg text-foreground">{row.value}</p>
              </div>
            ))}
          </div>
        </section>

        <section id="troubleshooting" class="scroll-mt-8 border-t border-border pt-12">
          <h2 class="font-mono text-2xl font-bold uppercase">{content.troubleshootingHeading}</h2>
          <div class="mt-6 grid gap-px border border-border bg-border xl:grid-cols-2">
            {troubleshooting.map((item) => (
              <article class="bg-background px-5 py-5">
                <h3 class="font-mono text-sm font-bold uppercase">{item.issue}</h3>
                <p class="mt-3 text-sm leading-relaxed text-muted">{item.fix}</p>
              </article>
            ))}
          </div>
        </section>
      </div>
    </div>
  </div>
</Layout>
