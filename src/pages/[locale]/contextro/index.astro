---
import Layout from '@/layouts/Layout.astro';
import Line from '@/components/Line.astro';
import getAvailableLocales from '@/lib/i18n.js';
import getTranslations from '@/lib/translations';
import { getRelativeLocaleUrl } from 'astro:i18n';

import '../../../styles/style.css';

export function getStaticPaths() {
  const availableLocales = getAvailableLocales();
  return availableLocales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
const t = getTranslations(locale);

const pillars = [
  {
    title: 'Hybrid retrieval',
    description: 'Semantic search, keyword search, graph search, reranking, and AST-aware compression in one local MCP toolchain.',
  },
  {
    title: 'Code graph awareness',
    description: 'Trace callers, callees, architecture hubs, and impact radius before you touch a file or start a refactor.',
  },
  {
    title: 'Persistent memory',
    description: 'Keep decisions, notes, and project knowledge across sessions so your agent compounds context instead of restarting cold.',
  },
  {
    title: 'Local by default',
    description: 'No cloud sync, no external API keys, and no source code leaving the machine where the repo already lives.',
  },
];

const workflows = [
  {
    title: 'Find the exact slice',
    description: 'Search for behavior, not filenames. Contextro narrows the problem down to the right symbol or code chunk in milliseconds.',
  },
  {
    title: 'Understand the blast radius',
    description: 'Before changing anything, inspect callers, callees, commit history, and architectural dependencies from the same context.',
  },
  {
    title: 'Ship with less token waste',
    description: 'Instead of dumping whole files into the model, pass only the precise snippets and relationships that matter.',
  },
];

const integrations = [
  'Claude Code',
  'Claude Desktop',
  'Cursor',
  'Windsurf',
  'Custom MCP clients',
  'Local Python workflows',
];

const proofPoints = [
  {
    eyebrow: 'For large codebases',
    title: 'Keep the model focused',
    body: 'Contextro reduces the amount of irrelevant code your agent needs to read, which means faster answers, lower token usage, and fewer wrong turns.',
  },
  {
    eyebrow: 'For refactors',
    title: 'See consequences before edits',
    body: 'Impact analysis and call graph traversal make it easier to understand what a change touches before you rename, delete, or move core symbols.',
  },
  {
    eyebrow: 'For teams',
    title: 'Turn repository knowledge into a reusable system',
    body: 'Memory, commit search, and architecture summaries help new contributors and agents converge on the same mental model of the codebase.',
  },
];
---

<Layout>
  <section class="border-b border-border px-6 md:px-8 pt-12 md:pt-16 pb-12 md:pb-16">
    <div class="grid gap-10 xl:grid-cols-[minmax(0,1.2fr)_minmax(320px,0.8fr)] xl:items-end">
      <div class="flex flex-col gap-6">
        <div class="flex flex-wrap items-center gap-3 text-[10px] font-mono uppercase tracking-[0.24em] text-muted">
          <span>{t.openSource}</span>
          <span class="opacity-40">/</span>
          <span>Local MCP server</span>
        </div>
        <div class="flex flex-col gap-4">
          <h1 class="font-mono text-[clamp(3.5rem,10vw,7rem)] font-bold uppercase leading-[0.88] tracking-tight">
            Contextro
          </h1>
          <p class="max-w-2xl text-base leading-relaxed text-muted">
            {t.contextroDesc}
          </p>
        </div>
        <div class="flex flex-wrap items-center gap-4">
          <a href={getRelativeLocaleUrl(locale, '/contextro/docs')} class="corner-effect select-none">
            <span class="corner"></span>
            <span class="relative z-10 block rounded-sm bg-primary px-4 py-2 text-xs font-mono uppercase tracking-[0.2em] text-primary-foreground">
              Read docs
            </span>
          </a>
          <a href="https://pypi.org/project/contextro/" target="_blank" rel="noopener noreferrer" class="corner-effect select-none">
            <span class="corner"></span>
            <span class="relative z-10 block rounded-sm bg-card px-4 py-2 text-xs font-mono uppercase tracking-[0.2em]">
              {t.viewOnPypi}
            </span>
          </a>
          <a href="https://github.com/jassskalkat/contextro-mcp" target="_blank" rel="noopener noreferrer" class="font-mono text-[10px] uppercase tracking-[0.2em] text-muted underline underline-offset-4 transition-colors hover:text-foreground">
            GitHub ↗
          </a>
        </div>
      </div>

      <div class="border border-border bg-card/50">
        <div class="border-b border-border px-5 py-4">
          <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-muted">Install</p>
          <div class="mt-3 flex flex-wrap items-center justify-between gap-3">
            <code class="font-mono text-sm text-foreground">pip install contextro</code>
            <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-muted">Python 3.10–3.12</span>
          </div>
        </div>
        <div class="grid gap-px bg-border sm:grid-cols-2">
          {t.stats.map((stat) => (
            <div class="bg-background px-5 py-5">
              <span class="font-mono text-3xl font-bold leading-none">{stat.value}</span>
              <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.16em] text-muted">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="px-6 md:px-8 py-12 md:py-16">
    <div class="grid gap-10 lg:grid-cols-[220px_minmax(0,1fr)]">
      <div>
        <p class="font-mono text-[10px] uppercase tracking-[0.24em] text-muted">Why it exists</p>
      </div>
      <div class="grid gap-px border border-border bg-border md:grid-cols-3">
        {workflows.map((item) => (
          <article class="bg-background px-5 py-6">
            <h2 class="font-mono text-lg font-bold uppercase">{item.title}</h2>
            <p class="mt-3 text-sm leading-relaxed text-muted">{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <Line />

  <section class="px-6 md:px-8 py-12 md:py-16">
    <div class="grid gap-10 lg:grid-cols-[220px_minmax(0,1fr)]">
      <div>
        <p class="font-mono text-[10px] uppercase tracking-[0.24em] text-muted">Core capabilities</p>
      </div>
      <div class="grid gap-px border border-border bg-border md:grid-cols-2">
        {pillars.map((pillar) => (
          <article class="bg-background px-5 py-6">
            <h2 class="font-mono text-lg font-bold uppercase">{pillar.title}</h2>
            <p class="mt-3 text-sm leading-relaxed text-muted">{pillar.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <Line />

  <section class="px-6 md:px-8 py-12 md:py-16">
    <div class="grid gap-10 lg:grid-cols-[220px_minmax(0,1fr)]">
      <div>
        <p class="font-mono text-[10px] uppercase tracking-[0.24em] text-muted">What you can ask</p>
      </div>
      <div class="grid gap-px border border-border bg-border md:grid-cols-2">
        {t.caps.map((item) => (
          <div class="bg-background px-5 py-5">
            <code class="font-mono text-sm text-foreground">{item.cmd}</code>
            <p class="mt-2 text-sm leading-relaxed text-muted">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Line />

  <section class="px-6 md:px-8 py-12 md:py-16">
    <div class="grid gap-10 lg:grid-cols-[220px_minmax(0,1fr)]">
      <div>
        <p class="font-mono text-[10px] uppercase tracking-[0.24em] text-muted">Works with</p>
      </div>
      <div class="grid gap-px border border-border bg-border sm:grid-cols-2 xl:grid-cols-3">
        {integrations.map((client) => (
          <div class="bg-background px-5 py-5">
            <p class="font-mono text-sm uppercase tracking-[0.16em]">{client}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Line />

  <section class="px-6 md:px-8 py-12 md:py-16">
    <div class="grid gap-px border border-border bg-border lg:grid-cols-3">
      {proofPoints.map((point) => (
        <article class="bg-background px-5 py-6">
          <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-muted">{point.eyebrow}</p>
          <h2 class="mt-3 font-mono text-lg font-bold uppercase">{point.title}</h2>
          <p class="mt-3 text-sm leading-relaxed text-muted">{point.body}</p>
        </article>
      ))}
    </div>
  </section>

  <Line />

  <section class="px-6 md:px-8 py-12 md:py-16">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="font-mono text-[10px] uppercase tracking-[0.24em] text-muted">Next step</p>
        <h2 class="mt-3 font-mono text-3xl font-bold uppercase leading-none">Go from overview to implementation</h2>
        <p class="mt-4 max-w-2xl text-sm leading-relaxed text-muted">
          Start with the docs if you want setup details, client configuration, command references, and the full search pipeline.
        </p>
      </div>
      <div class="flex flex-wrap items-center gap-4">
        <a href={getRelativeLocaleUrl(locale, '/contextro/docs')} class="corner-effect select-none">
          <span class="corner"></span>
          <span class="relative z-10 block rounded-sm bg-primary px-4 py-2 text-xs font-mono uppercase tracking-[0.2em] text-primary-foreground">
            Open docs
          </span>
        </a>
        <a href="https://pypi.org/project/contextro/" target="_blank" rel="noopener noreferrer" class="corner-effect select-none">
          <span class="corner"></span>
          <span class="relative z-10 block rounded-sm bg-card px-4 py-2 text-xs font-mono uppercase tracking-[0.2em]">
            Install from PyPI
          </span>
        </a>
      </div>
    </div>
  </section>
</Layout>
