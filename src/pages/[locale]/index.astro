---
import Layout from '@/layouts/Layout.astro';
import getAvailableLocales from '@/lib/i18n.js';
import getTranslations from '@/lib/translations';
import { getRelativeLocaleUrl } from 'astro:i18n';

import '../../styles/style.css';

export function getStaticPaths() {
  const availableLocales = getAvailableLocales();
  return availableLocales.map(locale => ({
    params: { locale }
  }));
}

const { locale } = Astro.params;
const t = getTranslations(locale);
---

<Layout>
  <section class="flex min-h-[calc(100vh-6rem)] items-center justify-center px-6 md:px-8 py-16 md:py-20 border-b border-border">
    <div class="mx-auto flex w-full max-w-4xl flex-col items-center gap-8 text-center">
      <div class="flex flex-col items-center gap-8">
        <p class="font-mono text-[10px] uppercase tracking-[0.25em] text-muted">
          {t.tagline}
        </p>

        <div class="flex flex-col items-center gap-6">
          <h1 class="font-mono font-bold leading-[0.88] tracking-tight text-[clamp(4rem,14vw,9rem)] uppercase">
            Distillation<br />Labs
          </h1>
          <p class="max-w-2xl text-sm md:text-base leading-relaxed text-muted">
            {t.description}
          </p>
        </div>

        <div class="flex flex-wrap items-center justify-center gap-4">
          <a href={getRelativeLocaleUrl(locale, '/contextro')} class="corner-effect select-none">
            <span class="corner"></span>
            <span class="relative z-10 block rounded-sm bg-primary px-4 py-2 text-xs font-mono uppercase tracking-[0.2em] text-primary-foreground">
              Explore Contextro
            </span>
          </a>
          <a href={getRelativeLocaleUrl(locale, '/contextro/docs')} class="corner-effect select-none">
            <span class="corner"></span>
            <span class="relative z-10 block rounded-sm bg-card px-4 py-2 text-xs font-mono uppercase tracking-[0.2em]">
              Read docs
            </span>
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>